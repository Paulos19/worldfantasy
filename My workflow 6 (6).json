    {
      "parameters": {
        "jsCode": "const rawOutput = $('AI Agent').first().json.output || \"\";\nconst messages = rawOutput.split('|').map(msg => msg.trim()).filter(msg => msg.length > 0);\n\nreturn messages.map(msg => {\n  let type = 'text';\n  let mediaUrl = null;\n  let textContent = msg;\n\n  // 1. Tenta achar uma URL dentro de um formato Markdown: [texto](url)\n  const markdownMatch = msg.match(/\\[.*?\\]\\((https?:\\/\\/[^\\s\\)]+)\\)/);\n\n  if (markdownMatch) {\n    mediaUrl = markdownMatch[1]; // Pega EXATAMENTE o que está dentro dos parênteses\n    type = 'media';\n    // Remove o bloco Markdown inteiro da legenda para ficar limpo\n    textContent = msg.replace(/\\[.*?\\]\\((https?:\\/\\/[^\\s\\)]+)\\)/g, '').trim();\n  } else {\n    // 2. Fallback: Se não for Markdown, procura uma URL solta no texto\n    // O pulo do gato: o [^\\s\\]\\)]+ impede que ele capture colchetes perdidos\n    const rawUrlMatch = msg.match(/(https?:\\/\\/[^\\s\\]\\)]+)/);\n    \n    if (rawUrlMatch) {\n      mediaUrl = rawUrlMatch[1];\n      type = 'media';\n      // Remove a URL da legenda\n      textContent = msg.replace(mediaUrl, '').trim();\n    }\n  }\n\n  return {\n    json: {\n      type: type,\n      text: textContent,\n      mediaUrl: mediaUrl,\n      typingDelayMs: 2000,\n      waitDelaySec: 2\n    }\n  };\n});"
      },
